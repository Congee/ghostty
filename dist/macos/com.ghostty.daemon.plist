<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ghostty.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/ghostty-daemon</string>
        <string>--listen</string>
        <string>unix:/tmp/ghostty-daemon.sock</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/ghostty-daemon.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/ghostty-daemon.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
